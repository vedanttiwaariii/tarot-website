{
  "name": "mystic-guidance-website",
  "version": "1.0.0",
  "description": "Modern website for Tarot Reader, Reiki Healer, and Water Diviner",
  "main": "index.js",
  "scripts": {
    "install-all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "setup": "node setup.js"
  },
  "keywords": [
    "tarot",
    "reiki",
    "spiritual",
    "website",
    "booking",
    "react",
    "nodejs",
    "mongodb"
  ],
  "author": "Mystic Guidance",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
