# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/krushnalaya-website?retryWrites=true&w=majority

# Security Keys
ADMIN_KEY=your-super-secure-admin-key-here
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Admin Configuration
ADMIN_EMAIL=admin@krushnalaya.com

# WhatsApp Configuration
WHATSAPP_NUMBER=+919893578135

# CORS Configuration
FRONTEND_URL=https://yourdomain.com